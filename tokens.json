{
  "$schema": "https://design-tokens.org/format",
  "meta": {
    "name": "LABBOR Design Code",
    "product": "Зуботехническая STUDIO — SaaS CMS",
    "version": "0.1.0",
    "theme": "dark-first",
    "accent": "lime",
    "font": "Montserrat"
  },
  "color": {
    "bg":        { "value": "#000000", "comment": "App canvas / page background" },
    "surface": {
      "1": { "value": "#141414", "comment": "Lowest card / nested field bg" },
      "2": { "value": "#171717", "comment": "Modal surface" },
      "3": { "value": "#1c1c1c", "comment": "Default card / panel" },
      "4": { "value": "#212121", "comment": "Card hover" },
      "5": { "value": "#292929", "comment": "Field (inside card)" },
      "6": { "value": "#333333", "comment": "Field (on canvas) / search" }
    },
    "line":      { "value": "#2a2a2a", "comment": "Dividers, hairlines, borders" },
    "accent": {
      "DEFAULT": { "value": "#bdff67", "comment": "Lime — primary action, selection, focus" },
      "press":   { "value": "#a8eb52", "comment": "Lime pressed/active" },
      "soft":    { "value": "#28391a", "comment": "Lime on dark — icon button bg" }
    },
    "brand": {
      "red":     { "value": "#d22934", "comment": "LABBOR logo mark" },
      "red-alt": { "value": "#da2525", "comment": "Notification dot" }
    },
    "text": {
      "primary":   { "value": "#ffffff" },
      "secondary": { "value": "#c5c5c5" },
      "tertiary":  { "value": "#b9b9b9" },
      "muted":     { "value": "#7e7e7e", "comment": "Labels, captions, placeholders" }
    },
    "status": {
      "done":   { "bg": "#33491f", "fg": "#bdff67", "comment": "Завершено / Выполнено" },
      "work":   { "bg": "#4a3d12", "fg": "#f4cf57", "comment": "В работе" },
      "wait":   { "bg": "#2f2f2f", "fg": "#b9b9b9", "comment": "Ожидает" },
      "dead":   { "bg": "#4a3434", "fg": "#ff9699", "comment": "Дедлайн / Срочно / нарушен срок" },
      "lab":    { "bg": "#33336e", "fg": "#aeb0ff", "comment": "В лабе" },
      "clinic": { "bg": "#1d4a63", "fg": "#79c7f0", "comment": "В клинике" }
    }
  },
  "font": {
    "family": { "value": "Montserrat, system-ui, sans-serif" },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "size": {
      "micro":   { "value": "13px" },
      "caption": { "value": "15px", "comment": "Field labels, meta" },
      "sm":      { "value": "17px" },
      "body":    { "value": "18px" },
      "md":      { "value": "20px" },
      "lg":      { "value": "21px", "comment": "Field value, search input" },
      "xl":      { "value": "23px", "comment": "Card title" },
      "2xl":     { "value": "28px", "comment": "Section title, modal title" },
      "3xl":     { "value": "34px", "comment": "Page title (order)" },
      "4xl":     { "value": "40px", "comment": "Dashboard title" },
      "stat":    { "value": "64px", "comment": "Stat number" }
    },
    "leading": { "tight": 1.15, "snug": 1.35, "normal": 1.5 }
  },
  "radius": {
    "field":  { "value": "15px" },
    "image":  { "value": "14px" },
    "card":   { "value": "26px" },
    "modal":  { "value": "26px" },
    "panel":  { "value": "30px" },
    "pill":   { "value": "999px", "comment": "Buttons, badges, search, avatars" }
  },
  "space": {
    "1": "6px", "2": "10px", "3": "14px", "4": "18px",
    "5": "22px", "6": "26px", "7": "30px", "8": "46px"
  },
  "size": {
    "rail":        { "value": "108px", "comment": "Left icon rail width" },
    "control":     { "value": "64px",  "comment": "Topbar pill / bell / search height" },
    "rail-btn":    { "value": "64px" },
    "avatar":      { "value": "60px" },
    "avatar-sm":   { "value": "46px" },
    "icon-btn":    { "value": "42px" },
    "tap-min":     { "value": "44px",  "comment": "Minimum hit target" }
  },
  "shadow": {
    "modal": { "value": "0 18px 40px rgba(0,0,0,.5)" },
    "toast": { "value": "0 16px 40px rgba(0,0,0,.5)" }
  },
  "motion": {
    "fast":   { "value": "150ms" },
    "base":   { "value": "180ms" },
    "view":   { "value": "320ms" },
    "ease":   { "value": "cubic-bezier(.2,.8,.2,1)", "comment": "Standard / entrance easing" }
  }
}
